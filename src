#include <Arduino.h>
#include <WiFi.h>
#include <WebSocketsServer.h>

// ══════════════════════════════════════════
//   CHANGE THESE 3 THINGS ONLY
// ══════════════════════════════════════════
const char* ssid      = "Jayanth";       // Your WiFi name
const char* password  = "64089087";   // Your WiFi password
const char* LOCATION  = "Anekal - Main Drainage Line";      // Your drain location name
// ══════════════════════════════════════════

#define SENSOR_PIN  4      // GPIO4 — Black wire from sensor
#define SIGNAL_THRESHOLD 60  // Alert if signal % goes above this

WebSocketsServer webSocket = WebSocketsServer(81);
bool lastState = HIGH;

// ─────────────────────────────────────────
// Build JSON string to send to website
// ─────────────────────────────────────────
String buildJSON(String type, int signal, String location) {
  String json = "{";
  json += "\"type\":\"" + type + "\",";
  json += "\"signal\":" + String(signal) + ",";
  json += "\"location\":\"" + location + "\",";
  json += "\"message\":\"";
  if (type == "METAL") {
    json += "METAL DETECTED - Object found in " + location;
  } else {
    json += "CLEAR - No material in " + location;
  }
  json += "\"}";
  return json;
}

// ─────────────────────────────────────────
// WebSocket Events
// ─────────────────────────────────────────
void webSocketEvent(uint8_t num, WStype_t type, uint8_t* payload, size_t length) {
  if (type == WStype_CONNECTED) {
    Serial.printf("✅ Website connected [client %u]\n", num);
    // Send a welcome message so website shows "Online"
    String welcome = buildJSON("CLEAR", 0, LOCATION);
    webSocket.sendTXT(num, welcome);
  }
  if (type == WStype_DISCONNECTED) {
    Serial.printf("❌ Website disconnected [client %u]\n", num);
  }
}

// ─────────────────────────────────────────
void setup() {
  Serial.begin(115200);
  pinMode(SENSOR_PIN, INPUT);

  // Connect WiFi
  Serial.print("\nConnecting to WiFi");
  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }

  Serial.println("\n✅ WiFi Connected!");
  Serial.print("🌐 Open website and enter this IP: ws://");
  Serial.print(WiFi.localIP());
  Serial.println(":81");

  // Start WebSocket
  webSocket.begin();
  webSocket.onEvent(webSocketEvent);
  Serial.println("🟢 WebSocket started on port 81\n");
}

// ─────────────────────────────────────────
void loop() {
  webSocket.loop();

  bool currentState = digitalRead(SENSOR_PIN);

  // ── METAL DETECTED (NPN sensor → goes LOW) ──
  if (currentState == LOW && lastState == HIGH) {

    // Signal strength: since it's digital, we send 90%
    // (Change this if you have analog sensor)
    int signal = 5;

    String json = buildJSON("METAL", signal, LOCATION);
    webSocket.broadcastTXT(json);

    Serial.println("⚠  METAL DETECTED! Sent: " + json);
    delay(300); // debounce
  }

  // ── CLEAR (sensor back to HIGH) ──
  if (currentState == HIGH && lastState == LOW) {

    int signal = 90; // low signal = clear

    String json = buildJSON("CLEAR", signal, LOCATION);
    webSocket.broadcastTXT(json);

    Serial.println("✓  CLEAR. Sent: " + json);
    delay(300);
  }

  lastState = currentState;
}
